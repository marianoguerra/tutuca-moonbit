///|
/// The generated module for the counter view, in full. This snapshot IS the
/// contract: read it, do not just refresh it.
test "the generated counter module" {
  inspect(
    @viewgen.generate(counter_html, name="Counter", source_file="counter.html"),
    content=(
      #|// GENERATED by `tutuca gen-views` from counter.html — DO NOT EDIT.
      #|// Regenerate with:
      #|//
      #|//   tutuca gen-views counter.html --name Counter --out <dir>
      #|//
      #|// The package this file lives in must import:
      #|//   "marianoguerra/tutuca/core" @tutuca, "marianoguerra/tutuca/component",
      #|//   "moonbitlang/core/debug"
      #|
      #|///|
      #|/// The views declared in counter.html.
      #|pub(all) enum CounterView {
      #|  Main
      #|} derive(Eq, @debug.Debug)
      #|
      #|///|
      #|pub fn CounterView::name(self : CounterView) -> String {
      #|  match self {
      #|    Main => "main"
      #|  }
      #|}
      #|
      #|///|
      #|/// The file-level style — pass as `common_style~`.
      #|pub let counter_common_style : String = ""
      #|
      #|///|
      #|/// The `data-global` style — pass as `global_style~`.
      #|pub let counter_global_style : String = ""
      #|
      #|///|
      #|/// Every bare `@on` handler name the views reference.
      #|pub(all) enum CounterInput {
      #|  Add
      #|  ResetCount
      #|  SetLabel
      #|} derive(Eq, @debug.Debug)
      #|
      #|///|
      #|pub fn CounterInput::name(self : CounterInput) -> String {
      #|  match self {
      #|    Add => "add"
      #|    ResetCount => "resetCount"
      #|    SetLabel => "setLabel"
      #|  }
      #|}
      #|
      #|///|
      #|pub fn CounterInput::parse(s : String) -> CounterInput? {
      #|  match s {
      #|    "add" => Some(Add)
      #|    "resetCount" => Some(ResetCount)
      #|    "setLabel" => Some(SetLabel)
      #|    _ => None
      #|  }
      #|}
      #|
      #|///|
      #|/// The Input arm of @component.Dispatch, decoded. Payload types are
      #|/// inferred from the argument shapes written at the call sites, so a
      #|/// handler added to counter.html breaks every `match` over this type
      #|/// until it is handled.
      #|pub(all) enum CounterMsg {
      #|  /// `@on.click="add …"`
      #|  Add(Double)
      #|  /// `@on.click="resetCount …"`
      #|  ResetCount
      #|  /// `@on.input, @on.keydown="setLabel …"`
      #|  SetLabel(String)
      #|  /// An Input dispatch the views do not declare, or a declared name
      #|  /// whose runtime arguments did not match the inferred shape.
      #|  Unknown(String, Array[@tutuca.Value])
      #|}
      #|
      #|///|
      #|/// None for Receive / Bubble / Response — those names are raised by
      #|/// component code, never written in a view, so the views cannot type them.
      #|pub fn CounterMsg::from_dispatch(d : @component.Dispatch) -> CounterMsg? {
      #|  guard d is Input(name, args) else { return None }
      #|  Some(
      #|    match (name, args) {
      #|      ("add", [Num(a0)]) => Add(a0)
      #|      ("resetCount", []) => ResetCount
      #|      ("setLabel", [Str(a0)]) => SetLabel(a0)
      #|      _ => Unknown(name, args)
      #|    },
      #|  )
      #|}
      #|
      #|///|
      #|/// State fields the views read at a view's ROOT scope. Reads under an
      #|/// @each, an @enrich-with, a push-view or an <x render> address the loop
      #|/// item or the child component, not this state, so they are not listed.
      #|pub let counter_fields : Array[String] = ["count", "history", "label"]
      #|
      #|///|
      #|/// The fields in `counter_fields` that `s` does not carry — assert this is
      #|/// empty in a test. Fields the component declares through `specs~` rather
      #|/// than through its state struct go in `extra~`.
      #|pub fn[S : ToJson] counter_missing_fields(
      #|  s : S,
      #|  extra? : Array[String] = [],
      #|) -> Array[String] {
      #|  let present : Map[String, Bool] = Map([])
      #|  if s.to_json() is Object(o) {
      #|    for k, _ in o {
      #|      present[k] = true
      #|    }
      #|  }
      #|  for k in extra {
      #|    present[k] = true
      #|  }
      #|  counter_fields.filter(f => !present.contains(f))
      #|}
      #|
      #|///|
      #|/// Constant `id` attributes in the views — typed selectors for tests.
      #|pub(all) enum CounterId {
      #|  Count
      #|  Dec
      #|  History
      #|  Inc
      #|  Label
      #|  Reset
      #|} derive(Eq, @debug.Debug)
      #|
      #|///|
      #|pub fn CounterId::id(self : CounterId) -> String {
      #|  match self {
      #|    Count => "count"
      #|    Dec => "dec"
      #|    History => "history"
      #|    Inc => "inc"
      #|    Label => "label"
      #|    Reset => "reset"
      #|  }
      #|}
      #|
      #|///|
      #|/// The `#id` CSS selector for this element.
      #|pub fn CounterId::selector(self : CounterId) -> String {
      #|  "#" + self.id()
      #|}
      #|
      #|
    ),
  )
}

///|
/// The compiled-tree module for the same view, in full. This snapshot IS the
/// contract for what the builders let the emitter leave out: no ns, no
/// node_id where it is None, no event ids, no data-vid (View::from_ir stamps
/// it), no ConstAttrs/DynAttrs (h derives it from the items).
test "the generated counter tree" {
  inspect(
    @viewgen.emit_ir_module(
      "Counter",
      "counter.html",
      @viewgen.split_file(counter_html),
    ),
    content=(
      #|// GENERATED by `tutuca gen-views` from counter.html — DO NOT EDIT.
      #|//
      #|// The views of Counter, already compiled: the @anode.ANode tree each one
      #|// parses into, plus its event table, written with anode's builders.
      #|// Passing counter_views() as `views~` means the template parser
      #|// never runs at startup.
      #|//
      #|// The package this file lives in must import:
      #|//   "marianoguerra/tutuca/anode"
      #|//
      #|// Every builder returns a FRESH tree: View::from_ir stamps and optimizes
      #|// it in place, and each component that adopts a view stamps its own
      #|// data-cid onto it.
      #|
      #|///|
      #|/// The compiled `main` view.
      #|fn counter_main_view_ir() -> @anode.View {
      #|  @anode.View::from_ir(
      #|    "main",
      #|    @anode.h("div", [@anode.attr("class", "counter")], [
      #|      @anode.h("h1", [], [
      #|        @anode.dyn_text(Field("label"), id=0),
      #|        @anode.text(": "),
      #|        @anode.h("span", [@anode.attr("id", "count")], [
      #|          @anode.dyn_text(Field("count"), id=1),
      #|        ]),
      #|      ]),
      #|      @anode.text(" "),
      #|      @anode.h("button", [@anode.attr("id", "inc"), @anode.eid(0)], [
      #|        @anode.text("+1"),
      #|      ]),
      #|      @anode.text(" "),
      #|      @anode.h("button", [@anode.attr("id", "dec"), @anode.eid(1)], [
      #|        @anode.text("-1"),
      #|      ]),
      #|      @anode.text(" "),
      #|      @anode.h("button", [@anode.attr("id", "reset"), @anode.eid(2)], [
      #|        @anode.text("reset"),
      #|      ]),
      #|      @anode.text(" "),
      #|      @anode.h("input", [@anode.attr("id", "label"), @anode.dyn_attr("value", Field("label")), @anode.eid(3)], []),
      #|      @anode.text(" "),
      #|      @anode.h("ul", [@anode.attr("id", "history")], [
      #|        @anode.each(3, Field("history"), @anode.h("li", [], [
      #|          @anode.dyn_text(Bind("value"), id=2),
      #|        ])),
      #|      ]),
      #|    ]),
      #|    [
      #|      [@anode.on("click", HandlerName(name="add", ns=Input), args=[@anode.const_num(1.0)])],
      #|      [@anode.on("click", HandlerName(name="add", ns=Input), args=[@anode.const_num(-1.0)])],
      #|      [@anode.on("click", HandlerName(name="resetCount", ns=Input))],
      #|      [@anode.on("input", HandlerName(name="setLabel", ns=Input), args=[Name("value")]), @anode.on("keydown", HandlerName(name="setLabel", ns=Input), args=[@anode.const_str("sent!")], modifiers=["send"])],
      #|    ],
      #|  )
      #|}
      #|
      #|///|
      #|/// The component's views, already compiled — pass as `views~` to
      #|/// @component.component.
      #|pub fn counter_views() -> Map[String, @anode.View] {
      #|  {
      #|    "main": counter_main_view_ir(),
      #|  }
      #|}
      #|
      #|
    ),
  )
}

///|
test "a view with $methods, several views and styles" {
  inspect(
    @viewgen.generate(
      (
        #|<style>.todo { display: grid }</style>
        #|<template>
        #|  <ul><li @each=".items"><x render-it as="row"></x></li></ul>
        #|  <button @on.click="$clearDone">clear</button>
        #|</template>
        #|<template id="row"><style>li { margin: 0 }</style><li><x text="@value"></x></li></template>
      ),
      name="TodoList",
      source_file="todo.html",
    ),
    content=(
      #|// GENERATED by `tutuca gen-views` from todo.html — DO NOT EDIT.
      #|// Regenerate with:
      #|//
      #|//   tutuca gen-views todo.html --name TodoList --out <dir>
      #|//
      #|// The package this file lives in must import:
      #|//   "marianoguerra/tutuca/core" @tutuca, "marianoguerra/tutuca/component",
      #|//   "moonbitlang/core/debug"
      #|
      #|///|
      #|/// The views declared in todo.html.
      #|pub(all) enum TodoListView {
      #|  Main
      #|  Row
      #|} derive(Eq, @debug.Debug)
      #|
      #|///|
      #|pub fn TodoListView::name(self : TodoListView) -> String {
      #|  match self {
      #|    Main => "main"
      #|    Row => "row"
      #|  }
      #|}
      #|
      #|///|
      #|/// The file-level style — pass as `common_style~`.
      #|pub let todo_list_common_style : String = ".todo { display: grid }"
      #|
      #|///|
      #|/// The `data-global` style — pass as `global_style~`.
      #|pub let todo_list_global_style : String = ""
      #|
      #|///|
      #|/// Every `$name` the views call.
      #|pub(all) enum TodoListMethod {
      #|  ClearDone
      #|} derive(Eq, @debug.Debug)
      #|
      #|///|
      #|pub fn TodoListMethod::name(self : TodoListMethod) -> String {
      #|  match self {
      #|    ClearDone => "clearDone"
      #|  }
      #|}
      #|
      #|///|
      #|/// Build `mutate~` from an exhaustive match over the names the views call.
      #|/// Return None for a name another bucket serves, or one of the mutators
      #|/// generated from the state's fields.
      #|pub fn[S] todo_list_mutate(
      #|  f : (TodoListMethod) -> ((S, Array[@tutuca.Value]) -> S)?,
      #|) -> Map[String, (S, Array[@tutuca.Value]) -> S] {
      #|  let out : Map[String, (S, Array[@tutuca.Value]) -> S] = Map([])
      #|  for m in ([ClearDone] : Array[TodoListMethod]) {
      #|    match f(m) {
      #|      Some(h) => out[m.name()] = h
      #|      None => ()
      #|    }
      #|  }
      #|  out
      #|}
      #|
      #|///|
      #|/// Build `compute~` from an exhaustive match over the names the views call.
      #|/// Return None for a name another bucket serves, or one of the mutators
      #|/// generated from the state's fields.
      #|pub fn[S] todo_list_compute(
      #|  f : (TodoListMethod) -> ((S, Array[@tutuca.Value]) -> @tutuca.Value)?,
      #|) -> Map[String, (S, Array[@tutuca.Value]) -> @tutuca.Value] {
      #|  let out : Map[String, (S, Array[@tutuca.Value]) -> @tutuca.Value] = Map([])
      #|  for m in ([ClearDone] : Array[TodoListMethod]) {
      #|    match f(m) {
      #|      Some(h) => out[m.name()] = h
      #|      None => ()
      #|    }
      #|  }
      #|  out
      #|}
      #|
      #|///|
      #|/// Build `swap~` from an exhaustive match over the names the views call.
      #|/// Return None for a name another bucket serves, or one of the mutators
      #|/// generated from the state's fields.
      #|pub fn[S] todo_list_swap(
      #|  f : (TodoListMethod) -> ((S, Array[@tutuca.Value], &@tutuca.Ctx) -> @tutuca.Value?)?,
      #|) -> Map[String, (S, Array[@tutuca.Value], &@tutuca.Ctx) -> @tutuca.Value?] {
      #|  let out : Map[String, (S, Array[@tutuca.Value], &@tutuca.Ctx) -> @tutuca.Value?] = Map([])
      #|  for m in ([ClearDone] : Array[TodoListMethod]) {
      #|    match f(m) {
      #|      Some(h) => out[m.name()] = h
      #|      None => ()
      #|    }
      #|  }
      #|  out
      #|}
      #|
      #|///|
      #|/// State fields the views read at a view's ROOT scope. Reads under an
      #|/// @each, an @enrich-with, a push-view or an <x render> address the loop
      #|/// item or the child component, not this state, so they are not listed.
      #|pub let todo_list_fields : Array[String] = ["items"]
      #|
      #|///|
      #|/// The fields in `todo_list_fields` that `s` does not carry — assert this is
      #|/// empty in a test. Fields the component declares through `specs~` rather
      #|/// than through its state struct go in `extra~`.
      #|pub fn[S : ToJson] todo_list_missing_fields(
      #|  s : S,
      #|  extra? : Array[String] = [],
      #|) -> Array[String] {
      #|  let present : Map[String, Bool] = Map([])
      #|  if s.to_json() is Object(o) {
      #|    for k, _ in o {
      #|      present[k] = true
      #|    }
      #|  }
      #|  for k in extra {
      #|    present[k] = true
      #|  }
      #|  todo_list_fields.filter(f => !present.contains(f))
      #|}
      #|
      #|
    ),
  )
}
