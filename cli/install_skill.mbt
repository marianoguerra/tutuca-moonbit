// `tutuca install-skill` (tools/cli/commands/install-skill.js). The JS CLI
// copies skill/ directories shipped next to the installed package; the
// native binary instead embeds them at compile time (skill_assets_gen.mbt,
// regenerated by `moon run --target native cmd/dev -- skill-embed`). Only
// the tutuca skill is bundled — the JS margaui/immutable-js selection flags
// don't exist here (those libraries are not part of the MoonBit port).
//
// The pure core decides everything decidable without a filesystem: flag
// parsing, help, the dry-run listing, and the write plan. The shell
// (cmd/main) resolves the base directory, refuses to overwrite existing
// skill files unless --force, creates directories and writes.

///|
/// What the shell should write: `files` are (path-relative-to-target,
/// contents); `target_rel` is the directory relative to the base the shell
/// resolves from `user_scope` (home dir vs cwd).
pub(all) struct SkillInstallPlan {
  target_rel : String // e.g. ".claude/skills/tutuca"
  user_scope : Bool
  force : Bool
  files : Array[(String, String)]
} derive(Debug, Eq)

///|
let install_skill_help : String =
  #|tutuca install-skill [--user | --project] [--dot-agents] [--dry-run] [--force]
  #|
  #|  Installs the bundled tutuca Claude Code skill into .claude/skills/tutuca/.
  #|  Defaults to --project (cwd); --user installs at ~/.claude/skills/.
  #|
  #|  --dot-agents installs into .agents/skills/ instead of .claude/skills/.
  #|  --dry-run prints the files that would be written without touching the filesystem.
  #|  --force overwrites existing files.
  #|
  #|  (The JS CLI also bundles margaui / immutable-js skills; the MoonBit port
  #|  ships only the tutuca skill.)
  #|

///|
/// Parse install-skill's own args and either finish purely (help, dry-run,
/// usage errors, missing assets) or hand the shell a write plan.
pub fn run_install_skill(args : Array[String], opts : GlobalOpts) -> Outcome {
  let mut user = false
  let mut project = false
  let mut dot_agents = false
  let mut dry_run = false
  let mut force = false
  for a in args {
    match a {
      "--user" => user = true
      "--project" => project = true
      "--dot-agents" => dot_agents = true
      "--dry-run" => dry_run = true
      "--force" | "-f" => force = true
      "-h" | "--help" =>
        return Done({ out: install_skill_help, err: "", exit_code: 0 })
      other =>
        return Done(
          error_emit(
            opts,
            err(
              CODE_USAGE_UNKNOWN_FLAG,
              "unknown flag '\{other}' for install-skill",
              hint="see `tutuca install-skill -h` for the accepted flags",
            ),
          ),
        )
    }
  }
  if opts.help {
    return Done({ out: install_skill_help, err: "", exit_code: 0 })
  }
  if user && project {
    return Done(
      error_emit(
        opts,
        err(
          CODE_USAGE_MUTUALLY_EXCLUSIVE,
          "--user and --project are mutually exclusive",
          hint="Use --user for ~/.claude/skills/ or --project (the default) for ./.claude/skills/.",
        ),
      ),
    )
  }
  if skill_files.is_empty() {
    return Done(
      error_emit(
        opts,
        err(
          CODE_SKILL_ASSETS_MISSING,
          "no skill assets embedded in this binary",
          hint="regenerate with `moon run --target native cmd/dev -- skill-embed` and rebuild",
        ),
      ),
    )
  }
  let base_dir = if dot_agents { ".agents/skills" } else { ".claude/skills" }
  let target_rel = "\{base_dir}/tutuca"
  if dry_run {
    let sb = StringBuilder::new()
    let shown = if user { "~/\{target_rel}" } else { target_rel }
    sb.write_string("would install tutuca skill → \{shown}\n")
    for pair in skill_files {
      sb.write_string("  + \{pair.0}\n")
    }
    return Done({ out: sb.to_string(), err: "", exit_code: 0 })
  }
  InstallSkill(opts, plan={
    target_rel,
    user_scope: user,
    force,
    files: skill_files,
  })
}

///|
/// The success text the shell prints after writing (JS install-skill.js).
pub fn install_skill_success(target_shown : String) -> String {
  "installed tutuca skill → \{target_shown}\n" +
  "Open a Claude Code session in this directory to use it.\n"
}

///|
/// The already-exists refusal (JS SKILL_TARGET_EXISTS), pre-rendered for the
/// shell once it has found existing skill files at the target.
pub fn install_skill_target_exists(opts : GlobalOpts, target : String) -> Emit {
  error_emit(
    opts,
    err(
      CODE_SKILL_TARGET_EXISTS,
      "\{target} already contains skill files",
      hint="Re-run with --force to overwrite, or --dry-run to see what would change.",
    ),
  )
}
