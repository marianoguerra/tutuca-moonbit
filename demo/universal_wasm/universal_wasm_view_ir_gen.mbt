        node: Dom({
          tag: "div",
          attrs: ConstAttrs({
            "class": LStr("card bg-base-100 border border-base-300 shadow-sm"),
          }),
          childs: [
            Dom({
              tag: "div",
              attrs: ConstAttrs({ "class": LStr("card-body gap-2 p-3") }),
              childs: [
                Dom({
                  tag: "input",
                  attrs: DynAttrs([
                    ConstA(
                      name="class",
                      val=Const(
                        lit=LStr("input input-bordered input-sm w-full"),
                        from_macro=false,
                      ),
                    ),
                    ConstA(
                      name="placeholder",
                      val=Const(
                        lit=LStr("Filter components…"),
                        from_macro=false,
                      ),
                    ),
                    Plain(name="value", val=Field("filterText")),
                    ConstA(
                      name="data-eid",
                      val=Const(lit=LNum(0.0), from_macro=false),
                    ),
                  ]),
                  childs: [],
                  ns: None,
                }),
                Text({ val: " " }),
                Show({
                  node_id: None,
                  val: Predicate(pred=IsEmpty, args=[Field("items")]),
                  node: Dom({
                    tag: "p",
                    attrs: ConstAttrs({
                      "class": LStr("text-sm italic opacity-60"),
                    }),
                    childs: [
                      Text({ val: "No components yet — drop a " }),
                      Dom({
                        tag: "code",
                        attrs: ConstAttrs({ "class": LStr("font-mono") }),
                        childs: [Text({ val: ".tutuca.tar.gz" })],
                        ns: None,
                      }),
                      Text({ val: " bundle." }),
                    ],
                    ns: None,
                  }),
                }),
                Text({ val: " " }),
                Hide({
                  node_id: None,
                  val: Predicate(pred=IsEmpty, args=[Field("items")]),
                  node: Dom({
                    tag: "ul",
                    attrs: ConstAttrs({
                      "class": LStr("menu menu-sm bg-base-100 rounded-box p-0"),
                    }),
                    childs: [
                      Each({
                        node_id: 1,
                        iter_info: {
                          val: Field("items"),
                          when_val: Some(
                            HandlerName(name="matchesFilter", ns=Alter),
                          ),
                          loop_with_val: None,
                          enrich_with_val: None,
                        },
                        node: RenderIt({ node_id: 0, view_val: None }),
                        from_render_each: true,
                      }),
                    ],
                    ns: None,
                  }),
                }),
              ],
              ns: None,
            }),
          ],
          ns: None,
        }),
      }),
      Text({ val: " " }),
      Show({
        node_id: None,
        val: Predicate(pred=IsTruthy, args=[Field("selected")]),
        node: Dom({
          tag: "div",
          attrs: ConstAttrs(Map([])),
          childs: [
            Render({ node_id: 2, val: Field("selected"), view_val: None }),
          ],
          ns: None,
        }),
      }),
    ],
    ns: None,
  })
  let events : Array[@anode.NodeEvents] = [
