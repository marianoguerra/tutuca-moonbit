///|
/// The compiled `main` view.
fn component_picker_main_view_ir() -> @anode.View {
  @anode.View::from_ir(
    "main",
    @anode.h("div", [@anode.attr("class", "w-full")], [
      @anode.hide(
        Predicate(pred=IsTruthy, args=[Field("selected")]),
        @anode.h(
          "div",
          [
            @anode.attr(
              "class", "card bg-base-100 border border-base-300 shadow-sm",
            ),
          ],
          [
            @anode.h("div", [@anode.attr("class", "card-body gap-2 p-3")], [
              @anode.h(
                "input",
                [
                  @anode.attr("class", "input input-bordered input-sm w-full"),
                  @anode.attr("placeholder", "Filter components…"),
                  @anode.dyn_attr("value", Field("filterText")),
                  @anode.eid(0),
                ],
                [],
              ),
              @anode.text(" "),
              @anode.show(
                Predicate(pred=IsEmpty, args=[Field("items")]),
                @anode.h(
                  "p",
                  [@anode.attr("class", "text-sm italic opacity-60")],
                  [
                    @anode.text("No components yet — drop a "),
                    @anode.h("code", [@anode.attr("class", "font-mono")], [
                      @anode.text(".tutuca.tar.gz"),
                    ]),
                    @anode.text(" bundle."),
                  ],
                ),
              ),
              @anode.text(" "),
              @anode.hide(
                Predicate(pred=IsEmpty, args=[Field("items")]),
                @anode.h(
                  "ul",
                  [
                    @anode.attr(
                      "class", "menu menu-sm bg-base-100 rounded-box p-0",
                    ),
                  ],
                  [
                    @anode.each(
                      1,
                      Field("items"),
                      @anode.render_it(0),
                      when_val=HandlerName(name="matchesFilter", ns=Alter),
                      from_render_each=true,
                    ),
                  ],
                ),
              ),
            ]),
          ],
        ),
      ),
      @anode.text(" "),
      @anode.show(
        Predicate(pred=IsTruthy, args=[Field("selected")]),
        @anode.h("div", [], [@anode.render(2, Field("selected"))]),
      ),
    ]),
    [[@anode.on("input", Method("setFilterText"), args=[Name("value")])]],
  )
}

///|
/// The component's views, already compiled — pass as `views~` to
/// @component.component.
pub fn component_picker_views() -> Map[String, @anode.View] {
  { "main": component_picker_main_view_ir() }
}

