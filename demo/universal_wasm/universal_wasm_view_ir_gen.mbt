// GENERATED by `tutuca gen-views` from universal_wasm.html — DO NOT EDIT.
//
// The views of UniversalWasm, already compiled: the @anode.ANode tree each one
// parses into, plus its event table. Passing universal_wasm_views() as
// `views~` means the template parser never runs at startup.
//
// Every builder returns a FRESH tree: View::from_ir stamps and optimizes
// it in place, and each component that adopts a view stamps its own
// data-cid onto it.

///|
/// The compiled `main` view.
fn universal_wasm_main_view_ir() -> @anode.View {
  let root : @anode.ANode = Dom({
    tag: "div",
    attrs: ConstAttrs({
      "class": LStr(
        "min-h-screen bg-base-200 text-base-content p-4 flex flex-col gap-3",
      ),
      "data-vid": LStr("main"),
    }),
    childs: [
      Dom({
        tag: "div",
        attrs: ConstAttrs({
          "class": LStr(
            "rounded-box border-2 border-dashed border-base-300 bg-base-100 p-4 text-center opacity-70",
          ),
          "data-droptarget": LStr("tutuca-wasm-component"),
        }),
        childs: [
          Text({ val: "\n    Drop a " }),
          Dom({
            tag: "code",
            attrs: ConstAttrs({ "class": LStr("font-mono") }),
            childs: [Text({ val: ".tutuca.tar.gz" })],
            ns: None,
          }),
          Text({ val: " bundle to register its wasm components\n  " }),
        ],
        ns: None,
      }),
      Dom({
        tag: "p",
        attrs: ConstAttrs({ "class": LStr("text-sm opacity-70") }),
        childs: [RenderText({ node_id: None, val: Field("status") })],
        ns: None,
      }),
      Text({ val: " " }),
      Render({ node_id: 0, val: Field("list"), view_val: None }),
    ],
    ns: None,
  })
  let events : Array[@anode.NodeEvents] = []
  @anode.View::from_ir(
    "main",
    root,
    @anode.ParseContext::from_ir(root, events),
    style="",
  )
}

///|
/// The component's views, already compiled — pass as `views~` to
/// @component.component.
pub fn universal_wasm_views() -> Map[String, @anode.View] {
  { "main": universal_wasm_main_view_ir() }
}

