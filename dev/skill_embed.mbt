// Pure half of the `skill-embed` task: turn the skill/tutuca/ file tree into
// a generated MoonBit source (cli/skill_assets_gen.mbt) embedding every file
// as a string constant — the bundled-assets story that unblocks the native
// CLI's `install-skill` (a binary has no package dir to copy from, unlike
// the JS CLI's findSkillsRoot()). cmd/dev walks + reads the files and hands
// them here; this builds the source text.

///|
/// Escape a file's contents as a MoonBit double-quoted string literal.
/// Escaping `\` first also neutralizes `\{` interpolation.
fn escape_mbt_string(s : String) -> String {
  let buf = StringBuilder::new()
  for c in s {
    match c {
      '\\' => buf.write_string("\\\\")
      '"' => buf.write_string("\\\"")
      '\n' => buf.write_string("\\n")
      '\r' => buf.write_string("\\r")
      '\t' => buf.write_string("\\t")
      _ => buf.write_char(c)
    }
  }
  buf.to_string()
}

///|
/// The generated cli/skill_assets_gen.mbt contents. `files` are
/// (path-relative-to-skill/tutuca, contents) pairs, in walk order.
pub fn skill_assets_source(files : Array[(String, String)]) -> String {
  let sb = StringBuilder::new()
  sb.write_string(
    (
      #|// GENERATED by `moon run --target native cmd/dev -- skill-embed` from
      #|// skill/tutuca/ — DO NOT EDIT. Embeds the tutuca Claude-Code skill in
      #|// the CLI so the native `install-skill` command can write it out.
      #|
      #|///|
      #|pub let skill_files : Array[(String, String)] = [
    ) +
    "\n",
  )
  for pair in files {
    let (path, contents) = pair
    sb.write_string("  (\"")
    sb.write_string(escape_mbt_string(path))
    sb.write_string("\", \"")
    sb.write_string(escape_mbt_string(contents))
    sb.write_string("\"),\n")
  }
  sb.write_string("]\n")
  sb.to_string()
}
