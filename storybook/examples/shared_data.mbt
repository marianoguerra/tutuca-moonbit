// Port of docs/examples/_shared-data.js — the sample list (Borges' "Celestial
// Emporium of Benevolent Knowledge" classification of animals) that the
// iteration examples share.

///|
pub fn items() -> Array[@tutuca.Value] {
  [
    Str("those belonging to the Emperor"),
    Str("embalmed ones"),
    Str("trained ones"),
    Str("suckling pigs"),
    Str("mermaids (or sirens)"),
    Str("fabled ones"),
    Str("stray dogs"),
    Str("those included in this classification"),
    Str("those that tremble as if they were mad"),
    Str("innumerable ones"),
    Str("those drawn with a very fine camel hair brush"),
    Str("et cetera"),
    Str("those that have just broken the vase"),
    Str("those that from afar look like flies"),
  ]
}
