///|
/// The fields in `composability_fields` that `s` does not carry — assert this is
/// empty in a test. Fields the component declares through `specs~` rather
/// than through its state struct go in `extra~`.
pub fn[S : ToJson] composability_missing_fields(
  s : S,
  extra? : Array[String] = [],
) -> Array[String] {
  let present : Map[String, Bool] = Map([])
  if s.to_json() is Object(o) {
    for k, _ in o {
      present[k] = true
    }
  }
  for k in extra {
    present[k] = true
  }
