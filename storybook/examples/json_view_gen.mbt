  out
}

///|
/// Build `swap~` from an exhaustive match over the names the views call.
/// Return None for a name another bucket serves, or one of the mutators
/// generated from the state's fields.
pub fn[S] json_object_key_val_swap(
  f : (JsonObjectKeyValMethod) -> ((S, Array[@tutuca.Value], &@tutuca.Ctx) -> @tutuca.Value?)?,
) -> Map[String, (S, Array[@tutuca.Value], &@tutuca.Ctx) -> @tutuca.Value?] {
  let out : Map[
    String,
    (S, Array[@tutuca.Value], &@tutuca.Ctx) -> @tutuca.Value?,
  ] = Map([])
  for m in ([SetKey] : Array[JsonObjectKeyValMethod]) {
    match f(m) {
      Some(h) => out[m.name()] = h
      None => ()
    }
  }
  out
}

///|
/// State fields the views read at a view's ROOT scope. Reads under an
/// @each, an @enrich-with, a push-view or an <x render> address the loop
/// item or the child component, not this state, so they are not listed.
pub let json_object_key_val_fields : Array[String] = ["key", "value"]

///|
/// The fields in `json_object_key_val_fields` that `s` does not carry — assert this is
/// empty in a test. Fields the component declares through `specs~` rather
/// than through its state struct go in `extra~`.
pub fn[S : ToJson] json_object_key_val_missing_fields(
  s : S,
  extra? : Array[String] = [],
) -> Array[String] {
  let present : Map[String, Bool] = Map([])
  if s.to_json() is Object(o) {
    for k, _ in o {
      present[k] = true
    }
  }
  for k in extra {
    present[k] = true
  }
  json_object_key_val_fields.filter(f => !present.contains(f))
}

///|
/// The views declared in json.html.
pub(all) enum JsonObjectView {
  Main
} derive(Eq, @debug.Debug)

///|
pub fn JsonObjectView::name(self : JsonObjectView) -> String {
  match self {
    Main => "main"
  }
}

///|
/// The file-level style — pass as `common_style~`.
pub let json_object_common_style : String = ""

///|
/// The `data-global` style — pass as `global_style~`.
pub let json_object_global_style : String = ""

///|
/// Every bare `@on` handler name the views reference.
pub(all) enum JsonObjectInput {
  AddItem
  OnDropOnItem
} derive(Eq, @debug.Debug)

///|
pub fn JsonObjectInput::name(self : JsonObjectInput) -> String {
  match self {
    AddItem => "addItem"
    OnDropOnItem => "onDropOnItem"
  }
}

///|
pub fn JsonObjectInput::parse(s : String) -> JsonObjectInput? {
  match s {
    "addItem" => Some(AddItem)
    "onDropOnItem" => Some(OnDropOnItem)
    _ => None
  }
}

///|
/// The Input arm of @component.Dispatch, decoded. Payload types are
/// inferred from the argument shapes written at the call sites, so a
/// handler added to json.html breaks every `match` over this type
/// until it is handled.
pub(all) enum JsonObjectMsg {
  /// `@on.click="addItem …"`
  AddItem
  /// `@on.drop="onDropOnItem …"`
  OnDropOnItem(@tutuca.Value, @tutuca.Value)
  /// An Input dispatch the views do not declare, or a declared name
  /// whose runtime arguments did not match the inferred shape.
  Unknown(String, Array[@tutuca.Value])
}

///|
/// None for Receive / Bubble / Response — those names are raised by
/// component code, never written in a view, so the views cannot type them.
pub fn JsonObjectMsg::of_dispatch(d : @component.Dispatch) -> JsonObjectMsg? {
  guard d is Input(name, args) else { return None }
  Some(
    match (name, args) {
      ("addItem", []) => AddItem
      ("onDropOnItem", [a0, a1]) => OnDropOnItem(a0, a1)
      _ => Unknown(name, args)
    },
  )
}

///|
/// Every `$name` the views call.
pub(all) enum JsonObjectMethod {
  RemoveInItemsAt
} derive(Eq, @debug.Debug)

///|
pub fn JsonObjectMethod::name(self : JsonObjectMethod) -> String {
  match self {
    RemoveInItemsAt => "removeInItemsAt"
